rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all: deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPER DEFINITIONS ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- CUSTOMER VALIDATION BLUEPRINT ---
    function isValidCustomer(data) {
      return data.id is string
        && data.name is string
        && data.taxId is string
        && data.address is string;
    }

    // --- FEE VALIDATION BLUEPRINT ---
    function isValidFee(data) {
      return data.id is string
        && data.description is string
        && (data.vatPercent is int || data.vatPercent is float)
        && data.isPayOnBehalf is bool;
    }

    // --- DEBIT NOTE VALIDATION BLUEPRINT ---
    function isValidDebitNote(data) {
      return data.id is string
        && data.companyName is string;
    }

    // --- SECURE MATCH BLOCKS ---
    match /customers/{customerId} {
      allow read: if true;
      allow create, update: if isValidId(customerId) && isValidCustomer(incoming());
      allow delete: if isValidId(customerId);
    }

    match /fees/{feeId} {
      allow read: if true;
      allow create, update: if isValidId(feeId) && isValidFee(incoming());
      allow delete: if isValidId(feeId);
    }

    match /history/{noteId} {
      allow read: if true;
      allow create, update: if isValidId(noteId) && isValidDebitNote(incoming());
      allow delete: if isValidId(noteId);
    }
  }
}
